{
    "name": "c-host/omeka-s-module-internet-archive-outbound-sync",
    "type": "omeka-s-module",
    "description": "Push Omeka S metadata to Internet Archive and publish Collecting submissions.",
    "license": "GPL-3.0-only",
    "autoload": {
        "psr-4": {
            "InternetArchiveOutboundSync\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InternetArchiveOutboundSyncTest\\": "test/"
        }
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit",
        "test:smoke": "php test/smoke.php"
    }
}
